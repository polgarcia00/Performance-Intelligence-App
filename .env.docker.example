# Safe defaults for local Docker development only.
POSTGRES_DB=performance_journal
POSTGRES_USER=performance_user
POSTGRES_PASSWORD=performance_password
POSTGRES_PORT=5432

# Container services resolve PostgreSQL by the Compose service name.
DATABASE_URL=postgresql://performance_user:performance_password@postgres:5432/performance_journal
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

BACKEND_PORT=4000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:4000/api
UPLOAD_SIZE_LIMIT=5242880
NODE_ENV=development
