{
  "name": "my-performance-journal-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "migrate": "node dist/database/migrate.js",
    "db:migrate:test": "npm run build && node dist/database/migrateTest.js",
    "seed": "node dist/database/seed.js",
    "test": "npm run test:unit",
    "test:unit": "npm run build && node --test dist/tests/*.test.js",
    "test:api": "npm run test:integration",
    "test:integration": "npm run build && node --test dist/integration-tests/*.test.js"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
