    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cssstyle": "^4.1.0",
    "jsdom": "^25.0.1",
    "typescript": "~6.0.0",
    "vite": "^6.3.6",
    "vitest": "^3.2.4",
